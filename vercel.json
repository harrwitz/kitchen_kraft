{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/*.py": {
      "includeFiles": "backend/*.json*"
    }
  },
  "rewrites": [
    {
      "source": "/(recipes|recipe/.*|search|recommend|cuisines|meal-types|ingredients/.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/((?!assets/.*|.*\\.js|.*\\.css|.*\\.png|.*\\.jpg|.*\\.svg|.*\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
